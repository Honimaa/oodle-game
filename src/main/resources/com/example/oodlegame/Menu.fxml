<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<!--
    MenuController necesita:
      · fx:id="lblBienvenido"  → setText("Bienvenido, " + usuario.getNombre())
      · onAction="#irPartida"
      · onAction="#irHistorial"
      · onAction="#cerrarSesion"
-->

<StackPane prefHeight="503" prefWidth="854" style="-fx-background-color: #0F1923;" xmlns="http://javafx.com/javafx/17.0.2-ea" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.oodlegame.controller.MenuController">

   <!-- ══════════════════════════════════════════
        FONDO: Círculos decorativos difusos
        Simulan el estilo de las imágenes de operadores
        pero integrados como formas, sin imágenes externas
   ══════════════════════════════════════════ -->
   <Pane mouseTransparent="true">

      <!-- + arriba izquierda -->
      <Circle centerX="110" centerY="120" fill="#1A3A5C" opacity="0.55" radius="88" />
      <Label layoutX="82.0" layoutY="61.0" mouseTransparent="true" style="-fx-font-size: 80px; -fx-font-weight: bold;                       -fx-text-fill: #3A5BD9; -fx-opacity: 0.7;" text="+" />

      <!-- − arriba derecha -->
      <Circle centerX="744" centerY="110" fill="#1A3D2B" opacity="0.55" radius="88" />
      <Label layoutX="716.0" layoutY="51.0" mouseTransparent="true" style="-fx-font-size: 80px; -fx-font-weight: bold;                       -fx-text-fill: #6AAA64; -fx-opacity: 0.7;" text="−" />

      <!-- × abajo izquierda -->
      <Circle centerX="100" centerY="400" fill="#3D1E4A" opacity="0.55" radius="80" />
      <Label layoutX="75.0" layoutY="348.0" mouseTransparent="true" style="-fx-font-size: 72px; -fx-font-weight: bold;                       -fx-text-fill: #9B59B6; -fx-opacity: 0.7;" text="×" />

      <!-- ÷ abajo derecha -->
      <Circle centerX="754" centerY="395" fill="#3D2E10" opacity="0.55" radius="80" />
      <Label layoutX="729.0" layoutY="343.0" mouseTransparent="true" style="-fx-font-size: 72px; -fx-font-weight: bold;                       -fx-text-fill: #C9B458; -fx-opacity: 0.7;" text="÷" />

      <!-- Línea decorativa horizontal centro -->
      <Rectangle fill="#1E2D40" height="2" opacity="0.8" width="300" x="277" y="248" />

   </Pane>

   <!-- ══════════════════════════════════════════
        CONTENIDO CENTRAL
   ══════════════════════════════════════════ -->
   <VBox alignment="CENTER" maxHeight="380" maxWidth="340" spacing="0">

      <!-- Logo / título del juego -->
      <VBox alignment="CENTER" spacing="4">

         <!-- Título principal -->
         <Label style="-fx-font-size: 52px; -fx-font-weight: bold;                           -fx-text-fill: #FFFFFF;" text="Ooodle" />

         <!-- Subtítulo decorativo -->
         <HBox alignment="CENTER" spacing="10">
            <Label style="-fx-font-size: 18px; -fx-font-weight: bold;                               -fx-text-fill: #3A5BD9;" text="+" />
            <Label style="-fx-font-size: 13px; -fx-text-fill: #5A7A8A;" text="El juego de las ecuaciones" />
            <Label style="-fx-font-size: 18px; -fx-font-weight: bold;                               -fx-text-fill: #6AAA64;" text="=" />
         </HBox>
      </VBox>

      <!-- Línea separadora -->
      <Region prefHeight="1" prefWidth="300" style="-fx-background-color: linear-gradient(to right, transparent, #3A5BD9, transparent);" />

      <!-- Bienvenida al usuario -->
      <Label fx:id="lblBienvenido" style="-fx-font-size: 22px; -fx-font-weight: bold;                       -fx-text-fill: #FFFFFF;" text="Bienvenido">
         <VBox.margin><Insets bottom="4" /></VBox.margin>
      </Label>

      <Label style="-fx-font-size: 12px; -fx-text-fill: #5A7A8A;" text="¿Listo para adivinar la ecuación?">
         <VBox.margin><Insets bottom="28" /></VBox.margin>
      </Label>

      <!-- ── Botón: Nueva Partida ── -->
      <Button fx:id="btnNewMatch" maxWidth="1.7976931348623157E308" onAction="#irPartida" style="-fx-background-color: #3A5BD9;                        -fx-text-fill: #FFFFFF;                        -fx-font-size: 15px; -fx-font-weight: bold;                        -fx-background-radius: 10;                        -fx-cursor: hand;                        -fx-padding: 13 0 13 0;" text="▶   Nueva Partida">
         <VBox.margin><Insets bottom="12" /></VBox.margin>
      </Button>

      <!-- ── Botón: Ver Historial ── -->
      <Button fx:id="btnHistory" maxWidth="1.7976931348623157E308" onAction="#irHistorial" style="-fx-background-color: transparent;                        -fx-border-color: #3A5BD9;                        -fx-border-radius: 10; -fx-background-radius: 10;                        -fx-border-width: 2;                        -fx-text-fill: #3A5BD9;                        -fx-font-size: 15px; -fx-font-weight: bold;                        -fx-cursor: hand;                        -fx-padding: 13 0 13 0;" text="☰   Ver Historial">
         <VBox.margin><Insets bottom="12" /></VBox.margin>
      </Button>

      <!-- ── Botón: Cerrar Sesión ── -->
      <Button fx:id="btnClose" maxWidth="1.7976931348623157E308" onAction="#cerrarSesion" style="-fx-background-color: transparent;                        -fx-border-color: #A04040;                        -fx-border-radius: 10; -fx-background-radius: 10;                        -fx-border-width: 2;                        -fx-text-fill: #C05050;                        -fx-font-size: 15px; -fx-font-weight: bold;                        -fx-cursor: hand;                        -fx-padding: 13 0 13 0;" text="⏻   Cerrar Sesión" />

      <VBox.margin>
         <Insets bottom="28" />
      </VBox.margin>

   </VBox>

</StackPane>
