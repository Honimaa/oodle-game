    <Region prefHeight="20" />

    <!-- ══════════════════════════════════════════
         BOTÓN ENVIAR INTENTO
         Llama a onEnviarIntento() en el controller
    ══════════════════════════════════════════ -->
    <HBox alignment="CENTER">
        <Button text="Enviar"
                onAction="#onEnviarIntento"
                prefWidth="180" prefHeight="45"
                style="-fx-font-size: 18px; -fx-font-weight: bold;
                       -fx-background-color: #0000CC; -fx-text-fill: #FFFFFF;
                       -fx-background-radius: 10; -fx-cursor: hand;" />
    </HBox>

