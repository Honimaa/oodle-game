<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox prefHeight="800" prefWidth="900" style="-fx-background-color: #FFFFFF;"
      xmlns="http://javafx.com/javafx/17.0.2-ea"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.oodlegame.controller.PartidaController">

    <padding>
        <Insets bottom="30" left="30" right="30" top="20" />
    </padding>

    <!-- ══════════════════════════════════════════
         HEADER
    ══════════════════════════════════════════ -->
    <HBox alignment="CENTER_LEFT" prefWidth="840">
        <Button fx:id="homeButton" onAction="#onHomeClicked"
                text="🏠"
                style="-fx-background-color: transparent;
                       -fx-border-color: #0000CC;
                       -fx-border-radius: 50; -fx-background-radius: 50;
                       -fx-font-size: 20px; -fx-cursor: hand;
                       -fx-text-fill: #0000CC; -fx-padding: 6 10 6 10;" />
        <Region HBox.hgrow="ALWAYS" />
        <Label text="Ooodle"
               style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #000000;" />
    </HBox>

    <Region prefHeight="20" />

    <!-- ══════════════════════════════════════════════════════════════
         FILAS DE ECUACIÓN
         Patrón: [rNc1] [rNop1] [rNc2] [rNop2] [rNc3] [rNop3] [rNc4] = [ansN]

         · Los operadores rNopM se asignan en initialize() según la ecuación generada
         · Los campos rNcM se colorean desde evaluarIntento()
         · Los ansN muestran el resultado esperado (igual en todas las filas, color rosa)
         · Solo la fila activa es editable; las demás están bloqueadas
    ══════════════════════════════════════════════════════════════ -->
    <VBox fx:id="rowsContainer" spacing="10">

        <!-- ─── FILA 1 ─── -->
        <HBox alignment="CENTER_LEFT" spacing="8">
            <TextField fx:id="r1c1" alignment="CENTER" prefHeight="70" prefWidth="80"
                       style="-fx-font-size: 22px; -fx-border-color: #CCCCCC;
                              -fx-border-radius: 6; -fx-background-radius: 6;
                              -fx-background-color: #FFFFFF;" />
            <Label fx:id="r1op1" alignment="CENTER" prefWidth="20"
                   style="-fx-font-size: 22px; -fx-text-fill: #999999;" text="-" />
            <TextField fx:id="r1c2" alignment="CENTER" prefHeight="70" prefWidth="80"
                       style="-fx-font-size: 22px; -fx-border-color: #CCCCCC;
                              -fx-border-radius: 6; -fx-background-radius: 6;
                              -fx-background-color: #FFFFFF;" />
            <Label fx:id="r1op2" alignment="CENTER" prefWidth="20"
                   style="-fx-font-size: 22px; -fx-text-fill: #999999;" text="×" />
            <TextField fx:id="r1c3" alignment="CENTER" prefHeight="70" prefWidth="80"
                       style="-fx-font-size: 22px; -fx-border-color: #CCCCCC;
                              -fx-border-radius: 6; -fx-background-radius: 6;
                              -fx-background-color: #FFFFFF;" />
            <Label fx:id="r1op3" alignment="CENTER" prefWidth="20"
                   style="-fx-font-size: 22px; -fx-text-fill: #999999;" text="+" />
            <TextField fx:id="r1c4" alignment="CENTER" prefHeight="70" prefWidth="80"
                       style="-fx-font-size: 22px; -fx-border-color: #CCCCCC;
                              -fx-border-radius: 6; -fx-background-radius: 6;
                              -fx-background-color: #FFFFFF;" />
            <Label alignment="CENTER" prefWidth="20"
                   style="-fx-font-size: 22px; -fx-text-fill: #999999;" text="=" />
            <Label fx:id="ans1" prefHeight="53" prefWidth="80" alignment="CENTER">
                <font><Font size="22.0" /></font>
            </Label>
        </HBox>

        <!-- ─── FILA 2 ─── -->
        <HBox alignment="CENTER_LEFT" spacing="8">
