<VBox prefHeight="780" prefWidth="900"
      style="-fx-background-color: #0F1923;"
      xmlns="http://javafx.com/javafx/17.0.2-ea"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.oodlegame.controller.PartidaController">

    <padding>
        <Insets bottom="24" left="36" right="36" top="22"/>
    </padding>

    <!-- ══════════════════════════════════════════
         HEADER
    ══════════════════════════════════════════ -->
    <HBox alignment="CENTER_LEFT">

        <Button fx:id="homeButton" onAction="#onHomeClicked"
                text="← Menú"
                style="-fx-background-color: transparent;
                       -fx-border-color: #3A5BD9;
                       -fx-border-radius: 8; -fx-background-radius: 8;
                       -fx-text-fill: #3A5BD9;
                       -fx-font-size: 13px; -fx-font-weight: bold;
                       -fx-cursor: hand; -fx-padding: 6 14 6 14;"/>

        <Region HBox.hgrow="ALWAYS"/>

        <!-- Título centrado -->
        <VBox alignment="CENTER">
            <Label text="Ooodle"
                   style="-fx-font-size: 30px; -fx-font-weight: bold;
                          -fx-text-fill: #FFFFFF;"/>
        </VBox>

        <Region HBox.hgrow="ALWAYS"/>

        <!-- Contador de intentos -->
        <VBox alignment="CENTER_RIGHT" spacing="2">
            <Label text="INTENTOS"
                   style="-fx-font-size: 9px; -fx-font-weight: bold;
                          -fx-text-fill: #5A7A8A;"/>
            <HBox spacing="4" alignment="CENTER_RIGHT">
                <!-- 6 puntos, se colorean desde el controller si se desea -->
                <Circle fx:id="dot1" radius="5" fill="#3A5BD9"/>
                <Circle fx:id="dot2" radius="5" fill="#3A5BD9"/>
                <Circle fx:id="dot3" radius="5" fill="#3A5BD9"/>
                <Circle fx:id="dot4" radius="5" fill="#3A5BD9"/>
                <Circle fx:id="dot5" radius="5" fill="#3A5BD9"/>
                <Circle fx:id="dot6" radius="5" fill="#3A5BD9"/>
            </HBox>
        </VBox>

    </HBox>

