         HEADER
    ══════════════════════════════════════════ -->
    <HBox alignment="CENTER_LEFT" prefWidth="840">

        <Button fx:id="homeButton" onAction="#onHomeClicked" style="-fx-background-color: transparent;                        -fx-border-color: #0000CC;                        -fx-border-radius: 50;                        -fx-background-radius: 50;                        -fx-font-size: 20px;                        -fx-cursor: hand;                        -fx-text-fill: #0000CC;                        -fx-padding: 6 10 6 10;" text="🏠" />

        <Region HBox.hgrow="ALWAYS" />

        <Label style="-fx-font-size: 36px;                       -fx-font-weight: bold;                       -fx-text-fill: #000000;" text="Ooodle" />
    </HBox>

    <Region prefHeight="20" />

    <!-- ══════════════════════════════════════════════════════════════
         FILAS DE ECUACIÓN
         Patrón por fila:
           [rNc1] [rNop1] [rNc2] [rNop2] [rNc3] [rNop3] [rNc4] = [rNResult]

         Desde el controller puedes:
           · Cambiar operador : rNopM.setText("+")  /  setText("×")  / etc.
           · Colorear campo   : rNcM.setStyle("... -fx-background-color: #color;")
           · Colorear resultado: rNResult.setStyle("... -fx-background-color: #color;")

         Colores sugeridos (definir como constantes en el controller):
           CORRECT   = #6AAA64   (verde)
           PARTIAL   = #C9B458   (amarillo/naranja)
           WRONG     = #787C7E   (gris oscuro)
           DEFAULT   = #FFFFFF   (blanco, sin evaluar)
           TARGET    = #F08080   (rosa, fila objetivo)
    ══════════════════════════════════════════════════════════════ -->
    <VBox fx:id="rowsContainer" spacing="10">

        <!-- ─── FILA 1 ─── -->
        <HBox alignment="CENTER_LEFT" spacing="8">
            <TextField fx:id="r1c1" alignment="CENTER" prefHeight="70" prefWidth="80" style="-fx-font-size: 22px; -fx-border-color: #CCCCCC;                               -fx-border-radius: 6; -fx-background-radius: 6;                               -fx-background-color: #FFFFFF;" />
            <Label fx:id="r1op1" alignment="CENTER" prefWidth="20" style="-fx-font-size: 22px; -fx-text-fill: #999999;" text="-" />
