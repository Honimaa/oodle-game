<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>

<StackPane xmlns="http://javafx.com/javafx/17.0.2-ea"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.oodlegame.controller.RegistroController"
           prefHeight="503" prefWidth="854"
           style="-fx-background-color: #0F1923;">

    <!-- ══════════════════════════════════════════
         FONDO DECORATIVO
    ══════════════════════════════════════════ -->
    <Pane mouseTransparent="true">
        <Circle centerX="854" centerY="250" radius="220"
                fill="#1A2535" opacity="0.8"/>
        <Circle centerX="0" centerY="260" radius="200"
                fill="#111B27" opacity="0.8"/>
        <Circle centerX="427" centerY="550" radius="130"
                fill="#1E2D55" opacity="0.4"/>

        <Label text="?" layoutX="60"  layoutY="30"
               style="-fx-font-size: 52px; -fx-font-weight: bold;
                      -fx-text-fill: #3A5BD9; -fx-opacity: 0.15;"/>
        <Label text="+" layoutX="740" layoutY="40"
               style="-fx-font-size: 52px; -fx-font-weight: bold;
                      -fx-text-fill: #6AAA64; -fx-opacity: 0.15;"/>
        <Label text="=" layoutX="55"  layoutY="400"
               style="-fx-font-size: 52px; -fx-font-weight: bold;
                      -fx-text-fill: #C9B458; -fx-opacity: 0.15;"/>
        <Label text="×" layoutX="745" layoutY="400"
               style="-fx-font-size: 52px; -fx-font-weight: bold;
                      -fx-text-fill: #9B59B6; -fx-opacity: 0.15;"/>

        <!-- línea vertical separadora -->
        <Rectangle x="426" y="40" width="2" height="423" fill="#1E2D40"/>
    </Pane>

    <!-- ══════════════════════════════════════════
         LAYOUT: dos columnas
    ══════════════════════════════════════════ -->
    <HBox>

        <!-- ─── COLUMNA IZQUIERDA: Branding ─── -->
        <VBox alignment="CENTER" spacing="20"
              prefWidth="427" prefHeight="503"
              style="-fx-background-color: transparent;">
            <padding><Insets left="50" right="44"/></padding>

            <!-- Badge -->
            <HBox alignment="CENTER" spacing="8">
                <Label text="◆"
                       style="-fx-font-size: 10px; -fx-text-fill: #3A5BD9;"/>
                <Label text="MATH PUZZLE GAME"
                       style="-fx-font-size: 10px; -fx-font-weight: bold;
                              -fx-text-fill: #3A5BD9;"/>
                <Label text="◆"
                       style="-fx-font-size: 10px; -fx-text-fill: #3A5BD9;"/>
            </HBox>

            <!-- Título -->
            <Label text="Ooodle"
                   style="-fx-font-size: 60px; -fx-font-weight: bold;
                          -fx-text-fill: #FFFFFF;"/>

            <!-- Descripción -->
            <Label text="Únete y empieza a adivinar ecuaciones. Cada partida es un nuevo reto matemático."
                   wrapText="true" maxWidth="300"
                   style="-fx-font-size: 13px; -fx-text-fill: #5A7A8A;
                          -fx-text-alignment: center;"/>

            <!-- Iconos de beneficios -->
            <VBox spacing="12" maxWidth="280">
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="✓"
                           style="-fx-font-size: 14px; -fx-font-weight: bold;
                                  -fx-text-fill: #6AAA64;
                                  -fx-background-color: #1A3D2B;
                                  -fx-background-radius: 50;
                                  -fx-padding: 2 7 2 7;"/>
                    <Label text="Guarda tu historial de partidas"
                           style="-fx-font-size: 12px; -fx-text-fill: #8BA3B8;"/>
                </HBox>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="✓"
                           style="-fx-font-size: 14px; -fx-font-weight: bold;
                                  -fx-text-fill: #6AAA64;
                                  -fx-background-color: #1A3D2B;
                                  -fx-background-radius: 50;
                                  -fx-padding: 2 7 2 7;"/>
                    <Label text="Compite y mejora tu promedio"
                           style="-fx-font-size: 12px; -fx-text-fill: #8BA3B8;"/>
                </HBox>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="✓"
                           style="-fx-font-size: 14px; -fx-font-weight: bold;
                                  -fx-text-fill: #6AAA64;
                                  -fx-background-color: #1A3D2B;
                                  -fx-background-radius: 50;
                                  -fx-padding: 2 7 2 7;"/>
                    <Label text="Ecuaciones nuevas cada partida"
                           style="-fx-font-size: 12px; -fx-text-fill: #8BA3B8;"/>
                </HBox>
            </VBox>

        </VBox>

        <!-- ─── COLUMNA DERECHA: Formulario ─── -->
        <VBox alignment="CENTER" spacing="0"
              prefWidth="427" prefHeight="503"
              style="-fx-background-color: #111B27;">
            <padding><Insets left="44" right="44" top="36" bottom="36"/></padding>

            <!-- Encabezado -->
            <Label text="Crear Cuenta"
                   style="-fx-font-size: 24px; -fx-font-weight: bold;
                          -fx-text-fill: #FFFFFF;">
                <VBox.margin><Insets bottom="4"/></VBox.margin>
            </Label>
            <Label text="Completa los campos para registrarte"
                   style="-fx-font-size: 12px; -fx-text-fill: #5A7A8A;">
                <VBox.margin><Insets bottom="20"/></VBox.margin>
            </Label>

            <!-- Correo -->
            <Label text="Correo Electrónico"
                   style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #8BA3B8;">
                <VBox.margin><Insets bottom="5"/></VBox.margin>
            </Label>
            <TextField fx:id="txtEmail" promptText="correo@ejemplo.com"
                       style="-fx-background-color: #1A2535;
                              -fx-border-color: #1E2D40; -fx-border-radius: 8;
                              -fx-background-radius: 8; -fx-border-width: 2;
                              -fx-text-fill: #FFFFFF; -fx-prompt-text-fill: #3A4A5A;
                              -fx-font-size: 13px; -fx-padding: 9 12 9 12;">
                <VBox.margin><Insets bottom="12"/></VBox.margin>
            </TextField>

            <!-- Usuario -->
            <Label text="Nombre de Usuario"
                   style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #8BA3B8;">
                <VBox.margin><Insets bottom="5"/></VBox.margin>
            </Label>
            <TextField fx:id="txtUser" promptText="usuario123"
                       style="-fx-background-color: #1A2535;
                              -fx-border-color: #1E2D40; -fx-border-radius: 8;
                              -fx-background-radius: 8; -fx-border-width: 2;
                              -fx-text-fill: #FFFFFF; -fx-prompt-text-fill: #3A4A5A;
                              -fx-font-size: 13px; -fx-padding: 9 12 9 12;">
                <VBox.margin><Insets bottom="12"/></VBox.margin>
            </TextField>

            <!-- Contraseña -->
            <Label text="Contraseña"
                   style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #8BA3B8;">
                <VBox.margin><Insets bottom="5"/></VBox.margin>
            </Label>
            <PasswordField fx:id="txtPassword" promptText="••••••••"
                           style="-fx-background-color: #1A2535;
                                  -fx-border-color: #1E2D40; -fx-border-radius: 8;
                                  -fx-background-radius: 8; -fx-border-width: 2;
                                  -fx-text-fill: #FFFFFF; -fx-prompt-text-fill: #3A4A5A;
                                  -fx-font-size: 13px; -fx-padding: 9 12 9 12;">
                <VBox.margin><Insets bottom="12"/></VBox.margin>
            </PasswordField>

            <!-- Confirmar contraseña -->
            <Label text="Confirmar Contraseña"
                   style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #8BA3B8;">
                <VBox.margin><Insets bottom="5"/></VBox.margin>
            </Label>
            <PasswordField fx:id="txtConfirmPassword" promptText="••••••••"
                           style="-fx-background-color: #1A2535;
                                  -fx-border-color: #1E2D40; -fx-border-radius: 8;
                                  -fx-background-radius: 8; -fx-border-width: 2;
                                  -fx-text-fill: #FFFFFF; -fx-prompt-text-fill: #3A4A5A;
                                  -fx-font-size: 13px; -fx-padding: 9 12 9 12;">
                <VBox.margin><Insets bottom="20"/></VBox.margin>
            </PasswordField>

            <!-- Botón crear -->
            <Button fx:id="btnNewUser"
                    text="Crear Usuario"
                    onAction="#Registrar"
                    maxWidth="1.7976931348623157E308"
                    style="-fx-background-color: #3A5BD9;
                           -fx-text-fill: #FFFFFF;
                           -fx-font-size: 14px; -fx-font-weight: bold;
                           -fx-background-radius: 10; -fx-cursor: hand;
                           -fx-padding: 12 0 12 0;">
                <VBox.margin><Insets bottom="12"/></VBox.margin>
            </Button>

            <!-- Volver al login -->
            <HBox alignment="CENTER" spacing="6">
                <Label text="¿Ya tienes cuenta?"
                       style="-fx-font-size: 12px; -fx-text-fill: #5A7A8A;"/>
                <Hyperlink text="Inicia sesión"
                           style="-fx-font-size: 12px; -fx-font-weight: bold;
                                  -fx-text-fill: #3A5BD9; -fx-border-color: transparent;
                                  -fx-padding: 0;"/>
            </HBox>

        </VBox>
    </HBox>

</StackPane>
